generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  @@map("users")
}

model Post {
  id            String            @id @default(uuid())
  previewFileId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  publishedAt   DateTime          @default(now())
  title         String            @db.VarChar(200)
  description   String?           @db.LongText
  content       String?           @db.LongText
  slug          String            @unique @db.VarChar(250)
  isPublished   Boolean           @default(false)
  isDeleted     Boolean           @default(false)
  departmentId  String?
  isPinned      Boolean           @default(false)
  Slide         MainSliderSlide[]
  Notification  Notification[]
  department    Department?       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  preview       File?             @relation("PostPreviewFile", fields: [previewFileId], references: [id])
  tags          TagsOnPosts[]

  @@index([departmentId])
  @@index([previewFileId])
  @@map("posts")
}

model Achievement {
  id        String   @id @default(uuid())
  label     String
  count     String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("achievements")
}

model Department {
  id            String   @id @default(uuid())
  title         String   @db.VarChar(200)
  slug          String   @unique @db.VarChar(250)
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.DateTime(0)
  updatedAt     DateTime @updatedAt
  previewFileId String?
  preview       File?    @relation("DepartmentPreviewFile", fields: [previewFileId], references: [id])
  posts         Post[]

  @@index([previewFileId])
  @@map("departments")
}

model Tag {
  id        String        @id @default(uuid())
  title     String        @db.VarChar(200)
  slug      String        @unique @db.VarChar(250)
  createdAt DateTime      @default(now())
  posts     TagsOnPosts[]

  @@map("tags")
}

model TagsOnPosts {
  postId     String
  tagId      String
  assignedAt DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
  @@index([tagId], map: "tags_on_posts_tagId_fkey")
  @@map("tags_on_posts")
}

model File {
  id             String            @id @default(uuid())
  originalName   String            @db.VarChar(200)
  mimeType       String            @db.VarChar(50)
  hash           String?           @unique @db.VarChar(64)
  type           FileType
  path           String            @db.VarChar(400)
  size           Int
  width          Int?
  height         Int?
  createdAt      DateTime          @default(now())
  BookCollection BookCollection[]  @relation("CollectionPreviewFile")
  books          Book[]            @relation("BookPreviewFile")
  departments    Department[]      @relation("DepartmentPreviewFile")
  club           Club[]            @relation("ClubPreviewFile")
  slide          MainSliderSlide[]
  posts          Post[]            @relation("PostPreviewFile")

  @@map("files")
}

model Event {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(500)
  content   String   @db.LongText
  phone     String   @db.VarChar(20)
  age       Int?
  place     String
  eventTime DateTime
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  @@map("events")
}

model MainSliderSlide {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  isDeleted   Boolean  @default(false)
  slideOrder  Int      @default(0)
  postId      String?
  imageFileId String?
  url         String?
  image       File?    @relation(fields: [imageFileId], references: [id])
  post        Post?    @relation(fields: [postId], references: [id])

  @@index([imageFileId])
  @@index([slideOrder])
  @@index([postId])
  @@map("main_slider_slides")
}

model Notification {
  id          String           @id @default(uuid())
  title       String           @db.VarChar(200)
  description String           @db.VarChar(200)
  type        NotificationType
  postId      String?
  startTime   DateTime         @default(now())
  endTime     DateTime?
  isDeleted   Boolean          @default(false)
  post        Post?            @relation(fields: [postId], references: [id])

  @@index([postId])
  @@map("notifications")
}

model Book {
  id            String             @id @default(uuid()) @db.VarChar(250)
  slug          String             @unique @db.VarChar(250)
  title         String             @db.VarChar(200)
  description   String             @db.LongText
  content       String             @db.LongText
  previewFileId String?
  isDeleted     Boolean            @default(false)
  isVideo       Boolean            @default(false)
  place         String             @db.VarChar(200)
  litresLink    String?
  createdAt     DateTime           @default(now())
  preview       File?              @relation("BookPreviewFile", fields: [previewFileId], references: [id])
  collections   BookOnCollection[]

  @@index([previewFileId])
  @@map("books")
}

model BookCollection {
  id            String             @id @default(uuid())
  label         String
  isDeleted     Boolean            @default(false)
  previewFileId String?
  createdAt     DateTime           @default(now())
  preview       File?              @relation("CollectionPreviewFile", fields: [previewFileId], references: [id])
  books         BookOnCollection[]

  @@index([previewFileId])
  @@map("book_collection")
}

model BookOnCollection {
  bookId        String
  collectionsId String
  assignedAt    DateTime       @default(now())
  book          Book           @relation(fields: [bookId], references: [id])
  collections   BookCollection @relation(fields: [collectionsId], references: [id])

  @@id([bookId, collectionsId])
  @@index([collectionsId], map: "books_on_collections_collectionsId_fkey")
  @@map("books_on_collections")
}

model NavigationItem {
  id          String           @id @default(uuid())
  title       String           @db.VarChar(100)
  to          String?          @db.VarChar(500)
  slug        String           @unique @db.VarChar(100)
  description String?          @db.VarChar(200)
  icon        String?          @db.VarChar(50)
  order       Int              @default(0)
  isExternal  Boolean          @default(false)
  target      String           @default("_self")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  parentId    String?
  parent      NavigationItem?  @relation("NavigationChildren", fields: [parentId], references: [id])
  children    NavigationItem[] @relation("NavigationChildren")

  @@index([parentId])
  @@index([order])
  @@map("navigation_items")
}

model Page {
  id        String  @id @default(uuid())
  title     String  @db.VarChar(200)
  content   String? @db.LongText
  isDeleted Boolean @default(false)
  slug      String? @unique @db.VarChar(200)
  blocks    Json?

  @@map("pages")
}

model Club {
  id            String @id @default(uuid())
  name          String @db.VarChar(80)
  description   String @db.VarChar(1024)
  member        String @db.VarChar(128)
  worktime      String @db.VarChar(64)
  workDirection Json

  previewFileId String?
  preview       File?   @relation("ClubPreviewFile", fields: [previewFileId], references: [id])

  @@index([previewFileId])
  @@map("clubs")
}

view games {
  id                String  @unique @db.VarChar(20)
  name              String? @db.VarChar(256)
  player_min        Int?
  player_max        Int?
  player_age        Int?
  short_description String? @db.VarChar(512)
  full_description  String? @db.VarChar(4192)
  cover_file        String? @db.VarChar(32)
  rules_file        String? @db.VarChar(32)
  genres            String? @db.VarChar(128)
  game_duration     String? @db.VarChar(64)
  game_year         String? @db.VarChar(32)
  status            Int?    @default(0)
  place             String? @db.VarChar(512)
  comment           String? @db.VarChar(1024)
  status_desc       String  @db.VarChar(64)
}

view genres {
  tag  String  @default("") @db.VarChar(20)
  desc String? @db.VarChar(32)
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
  EXHIBITION
}

enum NotificationType {
  success
  warning
  error
}
