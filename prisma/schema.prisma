generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model Post {
  id            String        @id @default(uuid())
  previewFileId String?
  createdAt     DateTime      @default(now()) @db.DateTime(3)
  updatedAt     DateTime      @updatedAt @db.DateTime(3)
  publishedAt   DateTime      @default(now()) @db.DateTime(3)
  title         String        @db.VarChar(200)
  description   String?       @db.LongText
  content       String?       @db.LongText
  slug          String        @unique @db.VarChar(250)
  isPublished   Boolean       @default(false)
  isDeleted     Boolean       @default(false)
  departmentId  String?
  isPinned      Boolean       @default(false)
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  preview       File?         @relation(fields: [previewFileId], references: [id], name: "PostPreviewFile")
  tags          TagsOnPosts[]

  @@index([departmentId])
  @@index([previewFileId])
  @@map("posts")
}

model Department {
  id            String   @id @default(uuid())
  title         String   @db.VarChar(200)
  slug          String   @unique @db.VarChar(250)
  isDeleted     Boolean  @default(false)
  preview       File?    @relation(fields: [previewFileId], references: [id], name: "DepartmentPreviewFile")
  createdAt     DateTime @default(now()) @db.DateTime(3)
  updatedAt     DateTime @updatedAt @db.DateTime(3)
  posts         Post[]
  previewFileId String?

  @@index([previewFileId])
  @@map("departments")
}

model Tag {
  id        String        @id @default(uuid())
  title     String        @db.VarChar(200)
  slug      String        @unique @db.VarChar(250)
  createdAt DateTime      @default(now()) @db.DateTime(3)
  posts     TagsOnPosts[]

  @@map("tags")
}

model TagsOnPosts {
  postId     String
  tagId      String
  post       Post     @relation(fields: [postId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])
  assignedAt DateTime @default(now())

  @@id([postId, tagId])
  @@map("tags_on_posts")
}

model File {
  id           String       @id @default(uuid())
  originalName String       @db.VarChar(200)
  mimeType     String       @db.VarChar(50)
  hash         String       @unique @db.VarChar(64)
  type         FileType
  path         String       @db.VarChar(400)
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime     @default(now())
  departments  Department[] @relation("DepartmentPreviewFile")
  posts        Post[]       @relation("PostPreviewFile")

  @@map("files")
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
}
