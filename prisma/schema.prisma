generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  @@map("users")
}

model Post {
  id            String            @id @default(uuid())
  previewFileId String?
  createdAt     DateTime          @default(now()) @db.DateTime(3)
  updatedAt     DateTime          @updatedAt @db.DateTime(3)
  publishedAt   DateTime          @default(now()) @db.DateTime(3)
  title         String            @db.VarChar(200)
  description   String?           @db.LongText
  content       String?           @db.LongText
  slug          String            @unique @db.VarChar(250)
  isPublished   Boolean           @default(false)
  isDeleted     Boolean           @default(false)
  departmentId  String?
  isPinned      Boolean           @default(false)
  department    Department?       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  preview       File?             @relation(fields: [previewFileId], references: [id], name: "PostPreviewFile")
  tags          TagsOnPosts[]
  Slide         MainSliderSlide[]
  Notification  Notification[]

  @@index([departmentId])
  @@index([previewFileId])
  @@map("posts")
}

model Department {
  id            String   @id @default(uuid())
  title         String   @db.VarChar(200)
  slug          String   @unique @db.VarChar(250)
  isDeleted     Boolean  @default(false)
  preview       File?    @relation(fields: [previewFileId], references: [id], name: "DepartmentPreviewFile")
  createdAt     DateTime @default(now()) @db.DateTime(0)
  updatedAt     DateTime @updatedAt
  posts         Post[]
  previewFileId String?

  @@index([previewFileId])
  @@map("departments")
}

model Tag {
  id        String        @id @default(uuid())
  title     String        @db.VarChar(200)
  slug      String        @unique @db.VarChar(250)
  createdAt DateTime      @default(now()) @db.DateTime(3)
  posts     TagsOnPosts[]

  @@map("tags")
}

model TagsOnPosts {
  postId     String
  tagId      String
  post       Post     @relation(fields: [postId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])
  assignedAt DateTime @default(now())

  @@id([postId, tagId])
  @@map("tags_on_posts")
}

model File {
  id           String            @id @default(uuid())
  originalName String            @db.VarChar(200)
  mimeType     String            @db.VarChar(50)
  hash         String?           @unique @db.VarChar(64)
  type         FileType
  path         String            @db.VarChar(400)
  size         Int
  width        Int?
  height       Int?
  createdAt    DateTime          @default(now())
  departments  Department[]      @relation("DepartmentPreviewFile")
  posts        Post[]            @relation("PostPreviewFile")
  Slide        MainSliderSlide[]

  @@map("files")
}

model Event {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(500)
  content   String   @db.LongText
  phone     String   @db.VarChar(20)
  age       Int?
  place     String
  eventTime DateTime
  createdAt   DateTime @default(now())
  isDeleted Boolean  @default(false)

  @@map("events")
}

model MainSliderSlide {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  isDeleted   Boolean  @default(false)
  slideOrder  Int      @default(0)
  postId      String?
  imageFileId String?
  url         String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  image       File?    @relation(fields: [imageFileId], references: [id])

  @@index([imageFileId])
  @@index([slideOrder])
  @@index([postId])
  @@map("main_slider_slides")
}

model Notification {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(200)
  description String    @db.VarChar(200)
  postId      String?
  startTime   DateTime  @default(now())
  endTime     DateTime?
  post        Post?     @relation(fields: [postId], references: [id])

  @@index([postId])
  @@map("notifications")
}

model Book {
  id          String  @id @default(uuid())
  title       String  @db.VarChar(200)
  description String  @db.LongText
  content     String  @db.LongText
  category    String? @db.VarChar(200)
  isDeleted   Boolean @default(false)
  isVideo     Boolean @default(false)
  litresLink  String?
  test        String

  @@map("books")
}

model NavigationItem {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(100)
  url         String?  @db.VarChar(500)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(200)
  icon        String?  @db.VarChar(50)
  order       Int      @default(0)
  isExternal  Boolean  @default(false)
  target      String   @default("_self")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parentId String?
  parent   NavigationItem?  @relation("NavigationChildren", fields: [parentId], references: [id])
  children NavigationItem[] @relation("NavigationChildren")

  @@index([parentId])
  @@index([order])
  @@map("navigation_items")
}

enum FileType {
  IMAGE
  DOCUMENT
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
  EXHIBITION
}
